{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Turn headroom proxy on",
            "type": "shell",
            "command": "docker compose -f headroom-compose.yml up -d",
            "runOptions": {
                "runOn": "folderOpen"
            }
        },
        {
            "label": "Turn headroom proxy off",
            "type": "shell",
            "command": "docker compose -f headroom-compose.yml down"
        }
    ]
}
